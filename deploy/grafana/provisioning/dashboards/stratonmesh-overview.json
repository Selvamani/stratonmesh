{
  "title": "StratonMesh — Overview",
  "uid": "stratonmesh-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["stratonmesh"],
  "panels": [
    {
      "id": 1,
      "title": "Active Stacks",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "count(stratonmesh_stack_state == 1) or vector(0)",
          "legendFormat": "running"
        }
      ]
    },
    {
      "id": 2,
      "title": "Failed Stacks",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "count(stratonmesh_stack_state == 0) or vector(0)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 3,
      "title": "Registered Nodes",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "count(stratonmesh_node_info) or vector(0)",
          "legendFormat": "nodes"
        }
      ]
    },
    {
      "id": 4,
      "title": "Catalog Blueprints",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "stratonmesh_catalog_blueprints_total or vector(0)",
          "legendFormat": "blueprints"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pipeline Deployments / min",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "rate(stratonmesh_pipeline_runs_total[1m]) or vector(0)",
          "legendFormat": "deployments/min"
        }
      ]
    },
    {
      "id": 6,
      "title": "Node CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "stratonmesh_node_cpu_percent",
          "legendFormat": "{{node_name}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Node Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "stratonmesh_node_memory_percent",
          "legendFormat": "{{node_name}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Pipeline Stage Duration (p95, ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "histogram_quantile(0.95, rate(stratonmesh_pipeline_stage_duration_ms_bucket[5m]))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Auto-scaler Events",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "rate(stratonmesh_autoscaler_scale_up_total[5m])",
          "legendFormat": "scale-up {{service}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "rate(stratonmesh_autoscaler_scale_down_total[5m])",
          "legendFormat": "scale-down {{service}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Stack State Timeline",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "stratonmesh_stack_state",
          "legendFormat": "{{stack_name}} ({{state}})"
        }
      ]
    },
    {
      "id": 11,
      "title": "StratonMesh Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{compose_project=~\".+\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
